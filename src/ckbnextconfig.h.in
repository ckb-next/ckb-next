#define CKB_NEXT_VERSION_STR "${ckb-next_VERSION}"
#define CKB_NEXT_ANIMATIONS_PATH "${CMAKE_INSTALL_PREFIX}/${INSTALL_DIR_ANIMATIONS}"
#define CKB_NEXT_UTILITIES_PATH "${CMAKE_INSTALL_PREFIX}/${INSTALL_DIR_UTILITIES}"

#define CKB_NEXT_PROFILE_VER ${ckb-next_PROFILE_VER}
#define CKB_NEXT_SETTINGS_VER ${ckb-next_SETTINGS_VER}

#cmakedefine DISABLE_UPDATER

#cmakedefine DEBUG_USB_SEND
#cmakedefine DEBUG_USB_RECV
#cmakedefine DEBUG_USB_INPUT
#cmakedefine DEBUG_MUTEX
#cmakedefine NO_FAIR_MUTEX_QUEUEING
#cmakedefine DEBUG_INPUT_SYNC
#cmakedefine FPS_COUNTER

#define CKB_NEXT_COPYRIGHT_YEAR "${ckb-next_COPYRIGHT_YEAR}"
#cmakedefine ckb_next_VERSION_IS_RELEASE
#define CKB_NEXT_DESCRIPTION "Open Source Driver for Corsair devices."

#include <assert.h>
// Number of characters allowed for key names.
#define N_KEYNAME_LENGTH      40
#define N_KEYNAME_STRLEN      39
#define N_KEYNAME_STR_REAL(x) #x
#define N_KEYNAME_STR(x)      N_KEYNAME_STR_REAL(x)
#define N_SCANF_KEYNAME       N_KEYNAME_STR(N_KEYNAME_STRLEN)
static_assert((N_KEYNAME_LENGTH == N_KEYNAME_STRLEN + 1), "N_KEYNAME_LENGTH must be 1 greater than N_KEYNAME_STRLEN");

#define CKB_NEXT_DAEMON_ETC_PATH "/etc/ckb-next-daemon/"
#define CKB_NEXT_DAEMON_SHARE_PATH "${CMAKE_INSTALL_PREFIX}/share/ckb-next-daemon/"
